##补全深度图的缺失区域
import os
import numpy as np
import scipy
from PIL import Image
from skimage.color import rgb2gray
from scipy.sparse.linalg import spsolve
import time
from tqdm import tqdm
from multiprocessing import Pool
import numpngw


base_dir = os.path.dirname(os.path.abspath(__file__))
dir_rgb = os.path.join(base_dir, "data_test", "image")
dir_depth_imple = os.path.join(base_dir, "data_test", "depth")
after_comple = os.path.join(base_dir, "data_test", "results")

def fill_depth_colorization(imgRgb=None, imgDepthInput=None, alpha=1):
    imgIsNoise = imgDepthInput == 0
    maxImgAbsDepth = np.max(imgDepthInput)
    
    # 防止全黑深度图导致除以0
    if maxImgAbsDepth == 0:
        return imgDepthInput

    imgDepth = imgDepthInput / maxImgAbsDepth
    imgDepth[imgDepth > 1] = 1
    (H, W) = imgDepth.shape
    numPix = H * W

    knownValMask = ~imgIsNoise
    grayImg = rgb2gray(imgRgb)

    # === 修复核心逻辑：确保 rows, cols, data 严格同步 ===
    A_data = []
    A_rows = []
    A_cols = []

    # 预计算索引，避免在循环中重复计算
    # 展平后的索引
    indexes = np.arange(numPix).reshape(H, W)

    for c in range(W):
        for r in range(H):
            # 如果是噪声点（需要补全的点），才参与计算邻域关系
            if knownValMask[r, c]: 
                # 如果是已知点，不需要通过邻居推导，直接跳过（后面由对角线矩阵处理）
                continue

            # 收集有效邻居
            neighbors_val = [] # 邻居的灰度值
            neighbors_idx = [] # 邻居的展平索引 (0 ~ numPix-1)
            
            # 遍历 3x3 窗口
            r_min, r_max = max(0, r - 1), min(r + 2, H)
            c_min, c_max = max(0, c - 1), min(c + 2, W)

            for rr in range(r_min, r_max):
                for cc in range(c_min, c_max):
                    if (rr, cc) != (r, c):
                        neighbors_val.append(grayImg[rr, cc])
                        neighbors_idx.append(indexes[rr, cc])

            # 如果没有邻居，跳过
            if not neighbors_val:
                continue

            # 计算权重 (基于颜色相似度)
            neighbors_val = np.array(neighbors_val)
            curVal = grayImg[r, c]
            # 高斯权重公式
            gvals = np.exp(-(neighbors_val - curVal) ** 2)
            g_sum = np.sum(gvals)
            
            if g_sum > 0:
                gvals /= g_sum # 归一化权重

            # === 关键修复点 ===
            # 同步添加数据，确保长度一致
            current_node_idx = indexes[r, c]
            
            # 对于当前点(r,c)，它与每一个邻居都有一个连接关系
            for k in range(len(neighbors_idx)):
                # 权重值 (注意这是拉普拉斯矩阵的非对角元素，通常为负)
                weight = -gvals[k]
                
                A_data.append(weight)
                A_rows.append(current_node_idx)     # 当前点是行
                A_cols.append(neighbors_idx[k])     # 邻居点是列

            # 添加对角线元素 (也就是公式中的 1，但在稀疏矩阵构造中，
            # 我们只需要把非对角元素填好，对角线由于 alpha 和 knownValMask 稍后处理)
            # 这里为了保持矩阵完整性，通常每一行的权重和为0(对于拉普拉斯)或者1
            # 原算法逻辑这里实际上是构建 A * x = b
            # 对于未知点：x_i - sum(w_j * x_j) = 0  => x_i + sum(-w_j * x_j) = 0
            # 所以当前点自身的系数应该是 1
            A_data.append(1.0)
            A_rows.append(current_node_idx)
            A_cols.append(current_node_idx)

    # 构建稀疏矩阵
    # coo_matrix 会自动累加重复坐标的值，非常适合这种构建方式
    A = scipy.sparse.coo_matrix((A_data, (A_rows, A_cols)), shape=(numPix, numPix))

    # 添加已知值的约束 (Soft Constraints)
    # 对于已知点，我们希望 x_i = depth_i，也就是 x_i * alpha = depth_i * alpha
    # 这里的实现方式是 A + alpha * I
    
    # 注意：原代码的逻辑是在 A 的基础上加上 G。
    # 上面的循环只处理了“未知点(噪声点)”。
    # 让我们查看原代码逻辑，原代码似乎是对所有噪声点构建方程。
    
    # 重新调整策略以完全匹配 Levin Colorization 算法：
    # 上面的循环构建了拉普拉斯矩阵的一项。
    # 必须确保矩阵大小完全匹配。
    
    G = scipy.sparse.diags(knownValMask.flatten() * alpha)
    
    # 将拉普拉斯矩阵与已知点约束相加
    # 注意：上面的循环只填充了未知点的行。已知点的行在 A 中全是 0 (因为 continue 了)
    # 所以 A + G 之后：
    # 1. 未知点行：x_i - sum(w * x_neighbors) = 0
    # 2. 已知点行：0 + alpha * x_i = alpha * d_i (这里可能有逻辑偏差，取决于原算法意图)
    
    # 原算法通常意图：
    # Minimize (x - sum(w*x))^2 + alpha * (x - d)^2
    # 这是一个最小二乘问题，求导后变成线性方程组。
    
    final_A = A + G
    b = np.multiply(knownValMask.flatten() * alpha, imgDepth.flatten())

    try:
        # 使用 CSR 格式加速求解
        final_A_csr = final_A.tocsr()
        new_vals = spsolve(final_A_csr, b)
        new_vals = new_vals.reshape(H, W)
    except Exception as e:
        print(f"Solver Error: {e}")
        return imgDepthInput

    denoisedDepthImg = new_vals * maxImgAbsDepth
    
    # 结果融合：保留原有的已知深度，填补原本是0的地方
    output = np.multiply(denoisedDepthImg, (1 - knownValMask)) + imgDepthInput
    return output

def process_image(rgb_filename):  ###文件路径和文件名，需要修改
    # 【修改部分 1】构建路径
    rgb_path = os.path.join(dir_rgb, rgb_filename)
    
    # 【修改部分 2】处理文件名差异
    # 你的RGB是 "um_000000.png"
    # 你的深度是 "um_000000-depth.png"
    # 所以需要把 .png 替换成 -depth.png
    depth_filename = rgb_filename.replace('.png', '-depth.png') 
    depth_path = os.path.join(dir_depth_imple, depth_filename)

    # 检查文件是否存在，不存在则跳过
    if not os.path.exists(rgb_path) or not os.path.exists(depth_path):
        print(f"跳过: 找不到对应的文件 \n RGB: {rgb_path} \n Depth: {depth_path}")
        return None

    print(f"正在处理: {rgb_filename} ...")

    img = Image.open(rgb_path)
    depth = Image.open(depth_path)

    try:
        img = np.array(img, dtype=np.float32)
        depth = np.array(depth, dtype=np.float32)
        
        # 归一化 RGB 并传入
        out = fill_depth_colorization(img / 255.0, depth)
    except Exception as e:
        print(f'Error processing image {rgb_filename}: {e}')
        return None

    # 【修改部分 3】保存逻辑优化 (移除 numpngw，直接用 PIL 保存)
    # 结果 out 是浮点数，先转回 uint8 如果是可视化，或者保留原样
    # 这里假设保存为可视化的 PNG (0-255)
    out_uint8 = out.astype(np.uint8)
    out_img = Image.fromarray(out_uint8)
    
    save_path = os.path.join(after_comple, rgb_filename)
    out_img.save(save_path) # 直接使用 PIL 保存
    
    return rgb_filename




def main():
    #global dir_rgb, dir_depth_imple
    #dir_rgb = "./data_test/image"
    #dir_depth_imple = "./data_test/depth"
    #after_comple = "./data_test/results"

    os.makedirs(after_comple, exist_ok=True)

    rgb_files = sorted(os.listdir(dir_rgb))
    with Pool(processes=1) as pool:
        results = list(tqdm(pool.imap(process_image, rgb_files), total=len(rgb_files)))

    print(f"Processed {len(results)} images.")


if __name__ == '__main__':
    print('开始')
    main()